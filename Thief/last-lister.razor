# Last Object or Last Target helper by Jaseowns
# UO Outlands
getlabel lastobject descObject
@setvar! lastObjectSeriel lastobject
sysmsg "Last Object: {{descObject}} {{lastObjectSeriel}}" 88
overhead "Last Object: {{descObject}} {{lastObjectSeriel}}" 88

getlabel lasttarget descTarget
@setvar! lastTargetSeriel lasttarget
sysmsg "Last Target: {{descTarget}} {{lastTargetSeriel}}" 88
overhead "Last Target: {{descTarget}} {{lastTargetSeriel}}" 88