@clearignore

while findtype "corpse" ground -1 -1 2 as corpsy
    getlabel corpsy corpslabel

    if instring corpslabel "corpse"
        // Monster corpse - skin if we have a knife
        if findtype 11552 backpack
            while not targetexists and not hidden
                skill 'forensicevaluation'
            endwhile
            wft 1500
            if targetexists and not hidden and find corpsy ground -1 -1 2
                sysmsg "Skinning.." 11
                wft 1500
                target 'self'
                settimer carveTimer 0
            endif
        endif
    else
        // Grey/player corpse - open for gold
        sysmsg "Opening grey corpse.." 33
        dclick corpsy
        wait 650
    endif

    @ignore corpsy
endwhile

@clearignore
script 'scav-harvester-loop'
