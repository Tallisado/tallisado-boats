@clearignore
while findtype "corpse" ground -1 -1 2 as corpsy and findtype 11552 backpack
    while not targetexists and not hidden
        skill 'forensicevaluation'
    endwhile
    wft 1500

    if targetexists and not hidden and find corpsy ground -1 -1 2
        sysmsg "Skinning corpse.." 11
        wft 1500
        target 'self'
        @ignore corpsy
        settimer carveTimer 0
    endif
endwhile
script 'scav-harvester-loop'