createlist summonList
clearlist summonList

pushlist summonList "Earth Elemental"
pushlist summonList "Earth Elemental"

settimer "ManaTimer" 10000

foreach summon in summonList
    overhead "Summoning"
    while diffmana > 50
        @setvar! canMeditate 0
        if not findbuff "Actively Meditating"
            if timerexists "ManaTimer"
                if timer "ManaTimer" > 10000
                    @setvar! canMeditate 1
                endif
            else
                @setvar! canMeditate 1
            endif
        endif
        if canMeditate = 1
            useskill "meditation"
            overhead "*meditating...*" 10
            settimer "ManaTimer" 0
        endif

        if diffhits >= 30
            return
        endif

        wait 500
    endwhile
    
    cast summon
    wait 5000
    overhead "done summon"
endfor
overhead "My pets? ..." 44
if findtype 14 ground -1 -1 2 as myPet
    overhead "I will keep watch, Master..." 44 myPet
    for 5
        if findtype 14 ground -1 -1 2 as myPet
            getlabel myPet myPetLabel
            if "earth elemental" in myPetLabel
                overhead "I will keep watch, Master..." 44 myPet
                menu myPet 3
                @ignore myPet
            endif 
        endif 
    endfor
endif