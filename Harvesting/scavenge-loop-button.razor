@clearignore

// Smart Harvest: one call skins all corpses within 2 tiles
if findtype "corpse" ground -1 -1 2 and findtype 11552 backpack
    while not targetexists and not hidden
        skill 'forensicevaluation'
    endwhile
    if targetexists and not hidden
        sysmsg "Skinning.." 11
        target 'self'
        settimer carveTimer 0
    endif
endif

// Open non-skinned corpses only (skip monster corpses by label)
while findtype "corpse" ground -1 -1 2 as jorpse
    getlabel jorpse jorpselabel
    if "corpse" in jorpselabel
        @ignore jorpse
    else
        dclick jorpse
        @ignore jorpse
        wait 500
    endif
endwhile

@clearignore
script 'scavenge-loop'
