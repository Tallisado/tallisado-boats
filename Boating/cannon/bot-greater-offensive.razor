# Boating/cannon/bot-greater-offensive.razor
# Hotkey-bindable: fire Bottom row Greater offensive ability.
clearsysmsg
hotkey '> Interrupt'
hotkey "Cancel Current Target"
say "[SecondGreaterAbility"
getlabel backpack ping
if insysmsg "fire its cannons again" or insysmsg "you must wait"
    overhead "Cannons Cooling..." 38
    hotkey "Play Script: tallisado-boats\Bots\PoonerBot\base"
    stop
endif
if insysmsg "target this ability?"
    @setvar! "cannon_cd" 15000
    @setvar! "cannon_msg" "*Greater Ability*"
    hotkey "Play Script: tallisado-boats\Bots\_utilities\cannon-fire-target"
    stop
endif
overhead "Ability Cooling..." 38
hotkey "Play Script: tallisado-boats\Bots\PoonerBot\base"
