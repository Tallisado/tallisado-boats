# Boating/cannon/bot-lesser-passive.razor
# Hotkey-bindable: trigger Bottom row Lesser passive ability.
clearsysmsg
say '[SecondLesserAbility'
getlabel backpack ping
if insysmsg "you must wait"
    overhead "Lesser Cooling..." 38
    hotkey "Play Script: tallisado-boats\Bots\PoonerBot\base"
