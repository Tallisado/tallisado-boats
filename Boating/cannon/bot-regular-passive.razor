# Boating/cannon/bot-regular-passive.razor
# Hotkey-bindable: trigger Bottom row Regular passive ability.
clearsysmsg
say '[SecondRegularAbility'
getlabel backpack ping
if insysmsg "you must wait"
    overhead "Regular Cooling..." 38
    hotkey "Play Script: Bots\PoonerBot\base"
    stop
elseif insysmsg "currently be repaired"
    overhead "It would be no use..." 38
else
    overhead '*Passive Regular Ability*' 87
endif
hotkey "Play Script: Bots\PoonerBot\base"
