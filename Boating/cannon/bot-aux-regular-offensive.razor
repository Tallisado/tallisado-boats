# Boating/cannon/bot-aux-regular-offensive.razor
# Hotkey-bindable: fire Bottom Auxiliary regular offensive ability.
clearsysmsg
hotkey '> Interrupt'
hotkey "Cancel Current Target"
say "[SecondAuxiliaryAbility"
getlabel backpack ping
if insysmsg "fire its cannons again" or insysmsg "you must wait"
    overhead "Cannons Cooling..." 38
    hotkey "Play Script: Bots\PoonerBot\base"
    stop
endif
if insysmsg "target this ability?"
    @setvar! "cannon_cd" 15000
    @setvar! "cannon_msg" "*Bot Aux Ability*"
    hotkey "Play Script: Bots\_utilities\cannon-fire-target"
    stop
endif
overhead "Ability Cooling..." 38
hotkey "Play Script: Bots\PoonerBot\base"
