# Boating/cannon/bot-aux-lesser-passive.razor
# Hotkey-bindable: trigger Bottom Auxiliary lesser passive ability.
clearsysmsg
say '[SecondAuxiliaryAbility'
getlabel backpack ping
if insysmsg "you must wait" or insysmsg "not currently reloading"
    overhead "Aux Cooling..." 38
    hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
    stop
else
    overhead '*Bot Aux Passive*' 87
endif
hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
