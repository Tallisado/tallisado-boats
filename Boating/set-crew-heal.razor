# Boating/set-crew-heal.razor
# Click a crew member to focus-bandage them. Esc or same target to clear.

hotkey "Cancel Current Target"
clearsysmsg

if varexist "CrewHeal"
    overhead "+ +" 63 "CrewHeal"
endif
if varexist "ManualTargetEnemy"
    overhead "x x" 33 "ManualTargetEnemy"
endif
overhead "Crew Heal..." 55

@setvar! "tallis_prev_lt" lasttarget
hotkey "Set Last Target"

while not targetexists
    pause 50
endwhile
while targetexists
    pause 50
endwhile
hotkey "Cancel Current Target"

if tallis_prev_lt = lasttarget
    # base.razor's target "CrewHeal" updates lasttarget to the crew member serial.
    # If the user re-focuses on the same crew member, tallis_prev_lt = lasttarget is
    # true — but that's a refresh, not a cancel. Only cancel if it's NOT a crew member.
    getlabel lasttarget tallis_ch_reflabel
    @setvar! tallis_ch_is_crew 0
    if "[Crewmember]" in tallis_ch_reflabel
        @setvar! tallis_ch_is_crew 1
    endif
    if tallis_ch_is_crew = 0
        if varexist "CrewHeal"
            @unsetvar "CrewHeal"
            overhead "CrewHeal cleared" 38
        else
            overhead "Cancelled" 38
        endif
        @unsetvar! tallis_prev_lt
        hotkey 'Play Script: uoo-scripts\Bots\PoonerBot\base'
        stop
    endif
endif

@unsetvar! tallis_prev_lt
getlabel lasttarget crewname
if "[Crewmember]" in crewname
    @setvar! "CrewHeal" lasttarget
    overhead "▼▼" 63 "CrewHeal"
    settimer jaseowns_CurrentBotTargetOverheadTimer jaseowns_CurrentBotTargetOverheadTimerCD
    clearsysmsg
    if findtype 3617 backpack as baids
        dclick baids
        wft 400
        if targetexists
            target "CrewHeal"
            pause 200
            getlabel backpack ping
            if insysmsg "You begin applying" or bandaging
                settimer undead_Ocean_CrewHealBandages_Timer 0
            else
                settimer undead_Ocean_CrewHealBandages_Timer undead_Ocean_CrewHealBandages_TimerCD
            endif
        else
            settimer undead_Ocean_CrewHealBandages_Timer undead_Ocean_CrewHealBandages_TimerCD
        endif
    else
        settimer undead_Ocean_CrewHealBandages_Timer undead_Ocean_CrewHealBandages_TimerCD
    endif
else
    overhead "Not a crew member!" 38
    settimer undead_Ocean_CrewHealBandages_Timer undead_Ocean_CrewHealBandages_TimerCD
endif
hotkey 'Play Script: uoo-scripts\Bots\PoonerBot\base'
