# Bapeths Smart Disembark and Recall Boarding
#
# Script will loop into 'Master Background' if you have it in your script library
#
# This script acts as both an embark and disembark hotkey
#
# Script starts here
overhead "Disembark Self"
pause 50
clearsysmsg
say '[Embark'
getlabel backpack ping
if insysmsg 'That is not a valid location' or insysmsg 'That is too far away' or insysmsg 'Target cannot be seen' or insysmsg 'The requested target is out of range'
    overhead 'Try Again...' 45
    replay
endif

if insysmsg "You do not have any valid at the moment"
    hotkey "Play Script: tallisado-boats\Bots\PoonerBot\base"
    stop
endif

if insysmsg "you are already"
    say "[disembark"
    wft 500
    while targetexists
        pause 50
    endwhile
else
    warmode off
    @unsetvar "ManualTargetEnemy"
endif
hotkey "Play Script: tallisado-boats\Bots\PoonerBot\base"