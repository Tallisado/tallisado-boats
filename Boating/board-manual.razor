# Boating/board-manual.razor
# Press after manually boarding an enemy ship (clicked on, walked on, etc.)
# Sets warmode and fires weapon special, same as board-all success path.

warmode on
if jaseowns_UseAbility1 = 1
    say "[WeaponAbility1"
    getlabel backpack ping
endif
if jaseowns_UseAbility2 = 1
    say "[WeaponAbility2"
    getlabel backpack ping
endif
if jaseowns_UseAbility3 = 1
    say "[WeaponAbility3"
    getlabel backpack ping
endif
hotkey "Play Script: tallisado-boats\Bots\PoonerBot\base"
