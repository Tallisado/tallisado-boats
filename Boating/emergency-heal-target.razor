hotkey 'Set Last Target'
wft 1000
while targetexists 
    //do nothing
endwhile
if not targetexists
    getlabel lasttarget desc
    if noto lasttarget = "friend" or noto lasttarget = "innocent"
        @setvar 'ManualTargetFriendlyEmergency' lasttarget
        @setvar 'ManualTargetFriendly' lasttarget
    elseif noto lasttarget = "murderer" or noto lasttarget = "enemy" or noto lasttarget = "hostile" or noto lasttarget = "criminal"
        @setvar 'ManualTargetEnemy' lasttarget
    endif
    overhead "<<.>>" 88 lasttarget
endif
hotkey "Play Script: Automation\PoonerBot\base"

