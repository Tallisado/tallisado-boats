# Boating/board-all.razor
# Hotkey-bindable: attempt to board enemy ship with all crew via boarding rope.
# Tries ManualTargetEnemy first, then closest grey/enemy/player targets.

if gumpexists 2881168634
    gumpclose 2881168634
endif

if not findtype 5370 backpack 0 as boardrope
    overhead "Out of boarding rope!" 38
    hotkey "Play Script: Bots\PoonerBot\base"
    stop
endif

if cooldown "Boarding Party"
    overhead "The crew needs more time..." 38
    hotkey "Play Script: Bots\PoonerBot\base"
    stop
endif

clearsysmsg
dclick boardrope
waitforgump 2881168634 500
gumpresponse 5
wft 500
hotkey 'Target Closest Grey Monster'
hotkey 'Target Closest Enemy Monster'
hotkey 'Next Enemy Player Target'
getlabel backpack ping

if targetexists
    overhead "Manual Target..." 88
endif
while targetexists
    pause 50
endwhile

if insysmsg 'That ship is too far away to board'
    overhead '*Argh, not close enough!*' 47
    gumpclose 2881168634
elseif insysmsg "Your boarding party fails"
    overhead "Yar, these ropes are no good!" 38
    cooldown "Boarding Party" 15000
elseif insysmsg 'You are already on that ship.'
    overhead 'We are boarded! Use ManualTargetEnemy!' 39
elseif insysmsg 'You successfully board the ship!'
    overhead "Yar, enemies abound!" 88
    cooldown "Boarding Party" 15000
    warmode on
elseif insysmsg 'The ship seems devoid of life'
    overhead 'Easy come easy go...' 79
    warmode on
endif
hotkey "Play Script: Bots\PoonerBot\base"
