if skill "Healing" >= 20
    clearsysmsg
    if not targetexists
        hotkey "Cancel Current Target"
        hotkey "Set Last Target"
        wft 500
        for 20
            if not targetexists
                break
            endif
            pause 25
        endfor
        @setvar "CrewHeal" lasttarget
        overhead "x" 88 "CrewHeal"
        if findtype 3617 backpack as baids
            dclick baids
            wft 500
            if targetexists
                target "CrewHeal"
            endif
        endif
        settimer undead_Ocean_CrewHealBandages_Timer 0
    elseif targetexists and varexist "CrewHeal"
        hotkey "Cancel Current Target"
        overhead "<Me>" 78 "CrewHeal"
    else
        overhead "Fumbled bandages .."
        script "Master Background"
    endif
endif
script "Master Background"
