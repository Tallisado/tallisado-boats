if skill "Healing" >= 20
    clearsysmsg
    if not targetexists
        hotkey "Cancel Current Target"
        hotkey "Set Last Target"
        wft 500
        for 20
            if not targetexists
                break
            endif
            pause 25
        endfor
        @setvar "CrewHeal" lasttarget
        overhead "x" 88 "CrewHeal"
        settimer undead_Ocean_CrewHealBandages_Timer undead_Ocean_CrewHealBandages_TimerCD
    elseif targetexists and varexist "CrewHeal"
        hotkey "Cancel Current Target"
        overhead "<Me>" 78 "CrewHeal"
    else
        overhead "Fumbled bandages .."
        script "Master Background"
    endif
endif
script "Master Background"
