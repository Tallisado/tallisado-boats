# Boating/bomb.razor
# Hotkey-bindable: drop ship bomb on nearby enemy ship, then use barrel from backpack.

while queued
    pause 50
endwhile

while findtype '5188' ground -1 -1 5 as bomb
    if findtype '5188' ground -1 -1 2 as bomb
        dclick bomb
    else
        overhead "Far Away!" 99 bomb
    endif
endwhile

if findtype "barrel" backpack as barrel
    dclick barrel
    getlabel backpack ping
    overhead "Bomb!" 88
endif
hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"