hotkey 'Set Last Target'
wft 500
while targetexists 
    //do nothing
endwhile
if not targetexists 
    getlabel lasttarget desc
    if noto lasttarget = "friend" or noto lasttarget = "innocent" //and "[Crewmember]" in desc
        @setvar 'ManualTargetFriendly' lasttarget
        overhead "*Heal Target*" 78 "ManualTargetFriendly"
        overhead "ManualTargetFriendly Set" 88 
    elseif noto lasttarget = "murderer" or noto lasttarget = "enemy"
        @setvar 'ManualTargetEnemy' lasttarget
        overhead "ManualTargetEnemy Set" 88
    endif
endif
hotkey "Play Script: Automation\PoonerBot\master"

