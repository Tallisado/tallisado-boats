hotkey 'Set Last Target'
wft 500
while targetexists 
    //do nothing
endwhile
if not targetexists 
    getlabel lasttarget desc
    if "[Crewmember]" in desc
        @setvar 'CrewHeal' lasttarget
        overhead "*Heal Target*" 78 "CrewHeal"
        overhead "CrewHeal Set" 88 
    else
        @setvar 'Manual Override' lasttarget
        overhead "Manual Override Set" 88 
    endif
endif
hotkey "Play Script: Automation\PoonerBot\master"