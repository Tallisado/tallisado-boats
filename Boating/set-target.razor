# Boating/set-target.razor
# Click a target to set focus-fire (ManualTargetEnemy). Esc or same target to clear.

hotkey "Cancel Current Target"
clearsysmsg

if varexist "ManualTargetEnemy"
    overhead "▼▼▼" 33 "ManualTargetEnemy"
endif
overhead "Kill..." 55

@setvar! "tallis_prev_lt" lasttarget
hotkey 'Set Last Target'

while not targetexists
    pause 50
endwhile
while targetexists
    pause 50
endwhile
hotkey "Cancel Current Target"

if tallis_prev_lt = lasttarget
    @unsetvar "ManualTargetEnemy"
    @unsetvar! tallis_prev_lt
    hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
    stop
endif

@unsetvar! tallis_prev_lt
@setvar 'ManualTargetEnemy' lasttarget
overhead "Kill..." 33 "ManualTargetEnemy"
hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
