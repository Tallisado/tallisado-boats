# Bots/_utilities/cannon-fire-target.razor
# Internal shared cannon targeting logic.
# Called by all cannon/ability scripts after the game has issued a target cursor.
#
# CALLER MUST SET before hotkey-ing here:
#   @setvar! "cannon_cd" <ms>       - cooldown to apply on fire (e.g. 13500 or 15000)
#   @setvar! "cannon_msg" <text>    - overhead message shown on success (e.g. "Fire!")
#
# Target priority: ShipSails -> Closest Enemy -> Closest Grey -> player aim
# On manual aim (priority 5): saves clicked target as ShipSails (sails/mast/rigging) or ManualTargetEnemy

wft 500

# Priority 1: Saved sails target - set via uoo-scripts\Boating\cannon\set-sails.razor
if varexist "ShipSails"
    target "ShipSails"
    getlabel backpack ping
    if insysmsg "Our cannons cannot reach that location." or insysmsg "That is too far away."
        overhead "Sails out of range - re-run set-sails or get closer" 78
    elseif insysmsg "Those cannons are out of ammunition"
        overhead "Out of Ammo!" 38
        @unsetvar! cannon_cd
        @unsetvar! cannon_msg
        hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
        stop
    elseif insysmsg "You may not fire onto your own ship!"
        overhead "Sails target is own ship! Clear with set-sails" 38
        @unsetvar "ShipSails"
    elseif not targetexists
        cooldown "Cannons" cannon_cd
        overhead "{{cannon_msg}}" 88
        @unsetvar! cannon_cd
        @unsetvar! cannon_msg
        hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
        stop
    endif
endif

# Priority 3: Auto-target closest enemy monster (skipped when cannon_manual_aim is set)
if not varexist "cannon_manual_aim"
    hotkey "Target Closest Enemy Monster"
    getlabel backpack ping
    if insysmsg "Our cannons cannot reach that location." or insysmsg "That is too far away."
        overhead "Enemy out of range!" 38
    elseif insysmsg "Those cannons are out of ammunition"
        overhead "Out of Ammo!" 38
        @unsetvar! cannon_cd
        @unsetvar! cannon_msg
        hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
        stop
    elseif insysmsg "You may not fire onto your own ship!"
        overhead "Too close!" 38
    elseif not targetexists
        cooldown "Cannons" cannon_cd
        overhead "{{cannon_msg}}" 88
        @unsetvar! cannon_cd
        @unsetvar! cannon_msg
        hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
        stop
    endif
endif

# Priority 4: Auto-target closest grey monster (skipped when cannon_manual_aim is set)
if not varexist "cannon_manual_aim"
    hotkey "Target Closest Grey Monster"
    getlabel backpack ping
    if insysmsg "Our cannons cannot reach that location." or insysmsg "That is too far away."
        overhead "Grey out of range!" 38
    elseif insysmsg "Those cannons are out of ammunition"
        overhead "Out of Ammo!" 38
        @unsetvar! cannon_cd
        @unsetvar! cannon_msg
        hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
        stop
    elseif insysmsg "You may not fire onto your own ship!"
        overhead "Too close!" 38
    elseif not targetexists
        cooldown "Cannons" cannon_cd
        overhead "{{cannon_msg}}" 88
        @unsetvar! cannon_cd
        @unsetvar! cannon_msg
        hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
        stop
    endif
endif
@unsetvar! cannon_manual_aim

# Priority 5: Wait for player to aim manually (cursor still up)
if insysmsg "No one matching" or insysmsg "out of range"
    overhead "Aim manually..." 88
endif
while targetexists
    pause 50
endwhile
getlabel backpack ping
if insysmsg "Our cannons cannot reach that location." or insysmsg "That is too far away."
    overhead "Out of Range!" 38
    @unsetvar! cannon_cd
    @unsetvar! cannon_msg
    hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
    stop
elseif insysmsg "Those cannons are out of ammunition"
    overhead "Out of Ammo!" 38
    @unsetvar! cannon_cd
    @unsetvar! cannon_msg
    hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
    stop
elseif insysmsg "You may not fire onto your own ship!"
    overhead "Too close!" 38
    @unsetvar! cannon_cd
    @unsetvar! cannon_msg
    hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
    stop
elseif not targetexists
    cooldown "Cannons" cannon_cd
    overhead "{{cannon_msg}}" 88
    getlabel lasttarget clickedlabel
    if "sails" in clickedlabel or "mast" in clickedlabel or "rigging" in clickedlabel
        @setvar "ShipSails" lasttarget
        overhead "Sails: {{clickedlabel}}" 66
    else
        @setvar "ManualTargetEnemy" lasttarget
    endif
    @unsetvar! cannon_cd
    @unsetvar! cannon_msg
    hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
    stop
endif

@unsetvar! cannon_cd
@unsetvar! cannon_msg
hotkey "Play Script: uoo-scripts\Bots\PoonerBot\base"
