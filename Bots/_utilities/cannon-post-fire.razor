# Bots/_utilities/cannon-post-fire.razor
# Internal: runs after a cannon shot lands successfully.
# Attempts Discordance on nearby creatures, then returns to base loop.

if not cooldown "Disco" and skill "Discordance" >= 50
    skill 'Discordance'
    wft 500
    hotkey 'Target self'
    hotkey "Cancel Current Target"
    getlabel backpack ping
    if insysmsg "creatures"
        overhead "Hear my sea song!" 91
        cooldown "Disco" 5000
    endif
endif
hotkey "Play Script: Bots\PoonerBot\base"
