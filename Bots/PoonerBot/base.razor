            getlabel jaseowns_ParryCodex jaseowns_ParryCodexDesc

            if "Shield Bash" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 1
            elseif "Warding" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 2
            elseif "Testudo" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 3
            elseif "Mirror" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 4
            elseif "Bulwark" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 5
            endif
            
            if findbuff "bleed" and jaseowns_Parry_SwitchToWardingIfBleeding = 1 and diffhits >= jaseowns_Parry_SwitchToWardingIfBleedingHpDiff
                @setvar! jaseowns_SwitchTo 2
            elseif findbuff "disease" and jaseowns_Parry_SwitchToWardingIfDisease = 1 and diffhits >= jaseowns_Parry_SwitchToWardingIfDiseaseHpDiff
                @setvar! jaseowns_SwitchTo 2
            elseif poisoned and jaseowns_Parry_SwitchToWardingIfPoison = 1 and diffhits >= jaseowns_Parry_SwitchToWardingIfPoisonHpDiff
                @setvar! jaseowns_SwitchTo 2
            elseif jaseowns_Parry_SwitchToBulwarkIfStandingStill = 1 and not cooldown "Bulwark"
                @setvar! jaseowns_SwitchTo 5
            elseif jaseowns_Parry_SwitchToShieldBashWhileMoving = 1 and cooldown "Moving"
                @setvar! jaseowns_SwitchTo 1
            elseif varexist jaseowns_Parry_SwitchToDefaultStance
                @setvar! jaseowns_SwitchTo jaseowns_Parry_SwitchToDefaultStance
            else
                @setvar! jaseowns_SwitchTo 0
            endif
            
            if jaseowns_ActiveParryCodex != jaseowns_SwitchTo
                if jaseowns_SwitchTo = 1
                    say "[ShieldsStance1"
                elseif jaseowns_SwitchTo = 2
                    say "[ShieldsStance2"
                elseif jaseowns_SwitchTo = 3
                    say "[ShieldsStance3"
                elseif jaseowns_SwitchTo = 4
                    say "[ShieldsStance4"
                elseif jaseowns_SwitchTo = 5
                    say "[ShieldsStance5"
                endif
                settimer jaseowns_Parry_SwitchCodexTimer 0
            endif
        endif
    endif

    // Attacking stuff
    if jaseowns_CurrentBotTargetAttacked = 1 and warmode

        if jaseowns_UseAbility1 = 1 and timer jaseowns_UseAbilityTimer >= jaseowns_UseAbilityTimerCD
            say "[WeaponAbility1"
            getlabel backpack jaseowns_PingCheck 
            if insysmsg "You cannot perform that ability yet."
                settimer jaseowns_UseAbilityTimer 0
            elseif insysmsg "You have not yet unlocked that weapon ability." or insysmsg "You do not have the required codex or skills to use that weapon ability."
                @setvar! jaseowns_UseAbility1 0
            else
                settimer jaseowns_UseAbilityTimer 0 
            endif
        endif 

        if jaseowns_UseAbility2 = 1 and timer jaseowns_UseAbilityTimer >= jaseowns_UseAbilityTimerCD
            say "[WeaponAbility2"
            getlabel backpack jaseowns_PingCheck 
            if insysmsg "You cannot perform that ability yet."
                settimer jaseowns_UseAbilityTimer 0
            elseif insysmsg "You have not yet unlocked that weapon ability." or insysmsg "You do not have the required codex or skills to use that weapon ability."
                @setvar! jaseowns_UseAbility2 0
            else
                settimer jaseowns_UseAbilityTimer 0 
            endif
        endif   
        
        # if i have poison skill and jaseowns_UseAbility3
