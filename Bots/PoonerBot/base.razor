        #   only use bane if target has ticks in label

        if jaseowns_UseAbility3 = 1 and timer jaseowns_UseAbilityTimer >= jaseowns_UseAbilityTimerCD
            if jaseowns_BOT_Poisoner_UseBane = 1
                if jaseowns_BOT_TargetPoisoned = 1
                    say "[WeaponAbility3"
                endif
            else
                say "[WeaponAbility3"
            endif
            getlabel backpack jaseowns_PingCheck 
            if insysmsg "You cannot perform that ability yet."
                settimer jaseowns_UseAbilityTimer 0
            elseif insysmsg "You have not yet unlocked that weapon ability." or insysmsg "You do not have the required codex or skills to use that weapon ability."
                @setvar! jaseowns_UseAbility3 0
            else
                settimer jaseowns_UseAbilityTimer 0 
            endif
        endif   
    
        if jaseowns_AutoExplodePot = 1 and findtype 3853 self 0 as jaseowns_Pot
            if timer jaseowns_AutoExplodePotTimer >= jaseowns_AutoExplodePotTimerCD
                dclick jaseowns_Pot
                wft 500
                target lasttarget
                if findtype 3853 self 0 as jaseowns_Pot2
                    getlabel jaseowns_Pot2 jaseowns_PotDesc
                    if "next" in jaseowns_PotDesc
                        if "12 seconds" in jaseowns_PotDesc
                            @setvar! jaseowns_AutoExplodePotTimerCD 12000
                        elseif "13 seconds" in jaseowns_PotDesc
                            @setvar! jaseowns_AutoExplodePotTimerCD 13000
                        elseif "14 seconds" in jaseowns_PotDesc
                            @setvar! jaseowns_AutoExplodePotTimerCD 14000
                        elseif "15 seconds" in jaseowns_PotDesc
                            @setvar! jaseowns_AutoExplodePotTimerCD 15000
                        endif
                        settimer jaseowns_AutoExplodePotTimer 0
                        cooldown "Purple Pot" 15000
                    endif
                endif
            endif
        endif
    
        if not queued and jaseowns_Potion_UseAgilityAutomatically = 1 and not findbuff "Agility" and findtype 3848 self as jaseowns_Potion
            if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
                dclick jaseowns_Potion
                settimer jaseowns_UseItemTimer 0
            endif
        endif
        
        if not queued and jaseowns_Potion_UseStrengthAutomatically = 1 and not findbuff "Strength" and findtype 3849 self as jaseowns_Potion
            if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
                dclick jaseowns_Potion
                settimer jaseowns_UseItemTimer 0
            endif
        endif
        
        if not queued and jaseowns_Potion_UseMagicResistAutomatically = 1 and not findbuff "Magic Resist" and findtype 3846 self as jaseowns_Potion
            if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
                dclick jaseowns_Potion
                settimer jaseowns_UseItemTimer 0
            endif
        endif
    
        if varexist jaseowns_HolySymbols
            if jaseowns_Chiv_UseDivineFuryAutomatically = 1 and 4 <= jaseowns_HolySymbols and skill "chivalry" >= 90 and timer jaseowns_DivineFuryTimer >= jaseowns_DivineFuryTimerCD
                say "[DivineFury"
                getlabel backpack jaseowns_PingCheck
                if insysmsg "Holy symbols remaining" 
                    cooldown "Divine Fury" 30000
                    settimer jaseowns_DivineFuryTimer 0
                endif
            elseif poisoned and jaseowns_Chiv_UseCleanseByFireAutomatically = 1 and 2 <= jaseowns_HolySymbols and skill "chivalry" >= 60 and timer jaseowns_CleanseByFireTimer >= jaseowns_CleanseByFireTimerCD
                say "[CleanseByFire"
                getlabel backpack jaseowns_PingCheck
                if insysmsg "Holy symbols remaining" 
                    cooldown "Cleanse By Fire" 30000
                    settimer jaseowns_CleanseByFireTimer 0
                endif
            elseif jaseowns_Chiv_UseEnemyOfOneAutomatically = 1 and 3 <= jaseowns_HolySymbols and skill "chivalry" >= 75 and timer jaseowns_EnemyOfOneTimer >= jaseowns_EnemyOfOneTimerCD
                say "[EnemyOfOne"
                getlabel backpack jaseowns_PingCheck
                if insysmsg "Holy symbols remaining" 
                    cooldown "Enemy Of One" 30000
                    settimer jaseowns_EnemyOfOneTimer 0
                endif  
            elseif jaseowns_Chiv_UseConsecrateWeaponAutomatically = 1 and 2 <= jaseowns_HolySymbols and skill "chivalry" >= 65 and timer jaseowns_ConsecrateWeaponTimer >= jaseowns_ConsecrateWeaponTimerCD
                say "[ConsecrateWeapon"
                getlabel backpack jaseowns_PingCheck
                if insysmsg "Holy symbols remaining" 
                    cooldown "Consecrate Weapon" 30000
                    settimer jaseowns_ConsecrateWeaponTimer 0
                endif
            endif
        endif
        
        
        if jaseowns_AutoTaunting = 1 or jaseowns_AutoAOETaunting = 1
            @setvar! jaseowns_TriggerAbility 0
            if cooldown "Taunting" or timer jaseowns_TauntingTimer < jaseowns_TauntingTimerCD
                // do nothing
            elseif not varexist jaseowns_Parry_AutoTauntHpDiffTrigger
                if hp >= 80
                    @setvar! jaseowns_TriggerAbility 1
                endif
            elseif diffhits <= jaseowns_Parry_AutoTauntHpDiffTrigger 
                @setvar! jaseowns_TriggerAbility 1
            endif
            if jaseowns_TriggerAbility = 1
                say "[Taunt"
                wft 500
                if targetexists 
                    if jaseowns_AutoAOETaunting = 1
                        hotkey "Target Self"
                    else
                        target jaseowns_CurrentBotTarget
                    endif
                    getlabel backpack jaseowns_PingCheck
                    if not targetexists 
                        if insysmsg "Cannot be seen"
                            // do nothing
                        else
                            cooldown "Taunting" 15000
                            settimer jaseowns_TauntingTimer 0
                        endif
                    else
                        hotkey "Cancel Current Target"
                    endif
                endif
            endif
        endif
    ### /Ocean Edit
    endif

    ### Ocean: Crew Attack
    if undead_Ocean_CrewAttackEnable = 1
        @setvar! tallis_crewatk_trigger 0
        if varexist "ManualTargetEnemy"
            if find "ManualTargetEnemy" ground -1 -1 25
                getlabel "ManualTargetEnemy" tallis_atk_check
                if "[Crewmember]" in tallis_atk_check
                    @unsetvar "ManualTargetEnemy"
                elseif noto "ManualTargetEnemy" = 1 or noto "ManualTargetEnemy" = 2
                    @unsetvar "ManualTargetEnemy"
                else
                    @setvar! tallis_crewatk_trigger 1
                endif
            else
                @unsetvar "ManualTargetEnemy"
            endif
        endif
        if jaseowns_CurrentBotTargetAttacked = 1 and warmode
            if find jaseowns_CurrentBotTarget ground
                getlabel jaseowns_CurrentBotTarget tallis_atk_check
                if "[Crewmember]" in tallis_atk_check
                    // own crew, skip
                elseif noto jaseowns_CurrentBotTarget = 1 or noto jaseowns_CurrentBotTarget = 2
                    // innocent or friendly, skip
                else
                    @setvar! tallis_crewatk_trigger 1
                endif
            endif
        endif
        if tallis_crewatk_trigger = 1
            @setvar! jaseowns_TriggerAbility 0
            if cooldown "CrewAttack" or timer undead_Ocean_CrewAttackTimer < undead_Ocean_CrewAttackTimerCD
                // do nothing
            else
                @setvar! jaseowns_TriggerAbility 1
            endif
            if jaseowns_TriggerAbility = 1
                overhead '!!Crew Attack!!' 54
                say "[CrewAttack"
                wft 500
                if targetexists
                    if varexist "ManualTargetEnemy"
                        getlabel ManualTargetEnemy tallis_crew_check
                        if "[Crewmember]" in tallis_crew_check
                            hotkey "Cancel Current Target"
                        else
                            target "ManualTargetEnemy"
                            getlabel backpack jaseowns_PingCheck
                            if targetexists
                                hotkey "Cancel Current Target"
                            endif
                        endif
                    else
                        getlabel jaseowns_CurrentBotTarget tallis_crew_check
                        if "[Crewmember]" in tallis_crew_check
                            hotkey "Cancel Current Target"
                        else
                            target jaseowns_CurrentBotTarget
                            getlabel backpack jaseowns_PingCheck
                            if targetexists
                                hotkey "Cancel Current Target"
                            endif
                        endif
                    endif
                else
                    hotkey "Cancel Current Target"
                endif
                cooldown "CrewAttack" 15000
                settimer undead_Ocean_CrewAttackTimer 0
            endif
        endif
