                else
                    overhead "I do not have an instrument" 34
                endif
                wft 500
            endif
            target backpack
            settimer jaseowns_BOT_BardBuffTimer 0
        endif
    endif

    if skill "Peacemaking" > 0
        if not findbuff "song of peacemaking" and timer jaseowns_BOT_BardBuffTimer >= 10000
            useskill 'Peacemaking'
            wft 500
            if insysmsg "What instrument"
