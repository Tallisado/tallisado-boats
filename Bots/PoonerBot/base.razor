                @setvar! jaseowns_BOT_CurrentWeapon jaseowns_RightHandWeapon
            elseif findlayer self lefthand as jaseowns_LeftHandWeapon
                @setvar! jaseowns_BOT_CurrentWeapon jaseowns_LeftHandWeapon
            endif
            if jaseowns_BOT_CurrentWeapon != 0
                getlabel jaseowns_BOT_CurrentWeapon jaseowns_BOT_CurrentWeaponDesc
                if "poison charge" in jaseowns_BOT_CurrentWeaponDesc
                    @setvar! jaseowns_BOT_Poisoner_UseBane 1
                    settimer jaseowns_BOT_PoisonWeaponTimer 4000
                    if jaseowns_Poison_AutomaticallyApplyAtSingleCharge = 1 
                       if "(1 lethal" in jaseowns_BOT_CurrentWeaponDesc or "(1 deadly" in jaseowns_BOT_CurrentWeaponDesc or "(1 greater" in jaseowns_BOT_CurrentWeaponDesc
                            menu jaseowns_BOT_CurrentWeapon 0
                            settimer jaseowns_BOT_PoisonWeaponTimer 0
                        endif
                    endif
                    // do nothing (add a timer to avoid checking this nonstop)
                else
                    menu jaseowns_BOT_CurrentWeapon 0
                    settimer jaseowns_BOT_PoisonWeaponTimer 0
                endif
            endif
        endif
    endif

# Potions remaining
