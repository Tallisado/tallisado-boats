                    @setvar! tallis_NeedLabelRefresh 1
                elseif timer tallis_TargetLabelTimer >= 500
                    @setvar! tallis_NeedLabelRefresh 1
                endif
                if tallis_NeedLabelRefresh = 1
                    for 3
                        if dead jaseowns_CurrentBotTarget
                            break
                        endif
                        getlabel jaseowns_CurrentBotTarget jaseowns_CurrentBotTargetDesc
                        if "-" in jaseowns_CurrentBotTargetDesc
                            // do nothing - try again
                        else
                            break
                        endif
                    endfor
                    @setvar! jaseowns_BOT_LastLabeledTarget jaseowns_CurrentBotTarget
                    settimer tallis_TargetLabelTimer 0
                endif
                @setvar! jaseowns_IgnoreCurrentBotTarget 0
                
                if "[Crewmember]" in jaseowns_CurrentBotTargetDesc
                    @setvar! jaseowns_CurrentBotTarget 0
                elseif "(summoned" in jaseowns_CurrentBotTargetDesc or "(bonded" in jaseowns_CurrentBotTargetDesc or "(tame" in jaseowns_CurrentBotTargetDesc
                    overhead "▼ Player pet - IGNORE ▼" 77 jaseowns_CurrentBotTarget
                    @setvar! jaseowns_IgnoreCurrentBotTarget 1
                elseif listexists jaseowns_IgnoreMobList
                    foreach jaseowns_IgnoreMob in jaseowns_IgnoreMobList
                        if jaseowns_IgnoreMob in jaseowns_CurrentBotTargetDesc
                            if timer jaseowns_IgnoreMobOverheadTimer >= jaseowns_IgnoreMobOverheadTimerCD and listexists jaseowns_IgnoreMobOverheadText
                                foreach jaseowns_Overhead in jaseowns_IgnoreMobOverheadText
                                    overhead jaseowns_Overhead jaseowns_IgnoreMobOverheadHue  jaseowns_CurrentBotTarget
                                endfor
                                settimer jaseowns_IgnoreMobOverheadTimer 0
                            endif
                            @setvar! jaseowns_IgnoreCurrentBotTarget 1
                        endif
                    endfor
                endif

                if jaseowns_IgnoreCurrentBotTarget = 1 or dead jaseowns_CurrentBotTarget
                    @setvar! jaseowns_CurrentBotTarget 0
                else
                    
                
                    attack jaseowns_CurrentBotTarget
                
                    #overhead "Current target: {{jaseowns_CurrentBotTargetDesc}} {{jaseowns_UsedSkillTimer}}"
                    
                    @setvar! jaseowns_BOT_TargetPoisoned 0
                    if "Ticks" in jaseowns_CurrentBotTargetDesc
                        @setvar! jaseowns_BOT_TargetPoisoned 1
                    endif
                    
                    @setvar! jaseowns_Bard_SkipPeace 0
                    if "pacified" in jaseowns_CurrentBotTargetDesc
                        @setvar! jaseowns_Bard_SkipPeace 1
                    endif
                    
                    # TODO: longshot bro
                    if findtype 5117|3920|31184|31186|30993 righthand or findtype 5117|3920|31184|31186|30993 lefthand
                        @setvar! jaseowns_DynamicRangeCheck 8
                    elseif findtype 30994|30990|30995|5042 lefthand
                        @setvar! jaseowns_DynamicRangeCheck 10
### OCEAN EDIT ###
                    elseif findtype 31169|31172 righthand or findtype 31169|31172 lefthand
                        @setvar! jaseowns_DynamicRangeCheck 10
### /OCEAN EDIT ###
                    else
                        @setvar! jaseowns_DynamicRangeCheck 2
                    endif

                    if jaseowns_Bard_CanPeacemake = 1 and jaseowns_Bard_SkipPeace = 0 and timer jaseowns_UsedSkillTimer >= 5000
                       
                        overhead "Peacemaking"
                        useskill 'Peacemaking'
                        wft 500
                        if insysmsg "What instrument"
                            if findtype 3740|3742|3762|3763|10245|20006|20008|20010|20012|20014|20016 backpack as jaseowns_Instrument 
                                target jaseowns_Instrument
                            else
                                overhead "I do not have an instrument" 34
                            endif
                            wft 500
                        endif
                        if targetexists 
                            target jaseowns_CurrentBotTarget
                            getlabel backpack jaseowns_PingCheck
                            if insysmsg "Target cannot be seen" or insysmsg "That is too far away."
                                if timer jaseowns_CurrentBotTargetUnableToAttackOverheadTimer >= jaseowns_CurrentBotTargetUnableToAttackOverheadTimerCD and listexists jaseowns_CurrentBotTargetUnableToAttackOverheadText
                                    foreach jaseowns_Overhead in jaseowns_CurrentBotTargetUnableToAttackOverheadText
                                        overhead jaseowns_Overhead jaseowns_CurrentBotTargetUnableToAttackOverheadHue jaseowns_CurrentBotTarget
                                    endfor
                                    settimer jaseowns_CurrentBotTargetOverheadTimer 0
                                endif
                                @setvar! jaseowns_CurrentBotTarget 0
                            else
                                settimer jaseowns_UsedSkillTimer 0
                                @setvar! jaseowns_CurrentBotTargetAttacked 1
                                @setvar! jaseowns_CurrentBotTargetGoodLOS 1
                            endif
                        endif
                        
                    # TODO : handle range of archery
                    elseif find jaseowns_CurrentBotTarget ground -1 -1 2
                        // assume we got it
                        @setvar! jaseowns_CurrentBotTargetAttacked 1
                    elseif not targetexists and jaseowns_CurrentBotTargetGoodLOS = 0
                        overhead "Arms lore"
                        useskill "ArmsLore"
                        wft 500
                        if targetexists 
                            target jaseowns_CurrentBotTarget
                            getlabel backpack jaseowns_PingCheck
                            if insysmsg "Target cannot be seen" or insysmsg "That is too far away."
                                if timer jaseowns_CurrentBotTargetUnableToAttackOverheadTimer >= jaseowns_CurrentBotTargetUnableToAttackOverheadTimerCD and listexists jaseowns_CurrentBotTargetUnableToAttackOverheadText
                                    foreach jaseowns_Overhead in jaseowns_CurrentBotTargetUnableToAttackOverheadText
                                        overhead jaseowns_Overhead jaseowns_CurrentBotTargetUnableToAttackOverheadHue jaseowns_CurrentBotTarget
                                    endfor
                                    settimer jaseowns_CurrentBotTargetOverheadTimer 0
                                endif
                                @setvar! jaseowns_CurrentBotTarget 0
                            else
                                @setvar! jaseowns_CurrentBotTargetGoodLOS 1
                                settimer jaseowns_UsedSkillTimer 3000
                                @setvar! jaseowns_CurrentBotTargetAttacked 1
                            endif
                        endif
                        if targetexists
                            hotkey "Cancel Current Target"
                        endif 
                    elseif jaseowns_CurrentBotTargetGoodLOS = 1 and find jaseowns_CurrentBotTarget ground -1 -1 jaseowns_DynamicRangeCheck 
                        @setvar! jaseowns_CurrentBotTargetAttacked 1
                    endif
                endif
            else
                @setvar! jaseowns_CurrentBotTarget 0
                @setvar! jaseowns_CurrentBotTargetGoodLOS 0
            endif
        endif
    else
        @setvar! jaseowns_CurrentBotTarget 0
        @setvar! jaseowns_CurrentBotTargetGoodLOS 0
        // do nothing
    endif
    

    #####
    ## Parry Codex Options
    ###
    if skill "Parry" >= 80 
