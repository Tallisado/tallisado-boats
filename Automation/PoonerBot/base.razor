@setvar! jaseowns_RedPouchCountTotal 0

while not dead

    while insysmsg "You deliver a poison sting"
        cooldown "Poison Sting" 5000
    endwhile

    // Handle manual bandage
    while insysmsg "You begin applying" or insysmsg "You begin using veterinary supplies"
        settimer jaseowns_BandageTimer 0
    endwhile

    // Reset the timer if we finished
    while insysmsg "You finish applying" or insysmsg "You heal what little" or insysmsg "barely help" or insysmsg "You fail to resurrect" or insysmsg "You are able to resurrect" or insysmsg "You finish using veterinary supplies" or insysmsg "You or your nearby followers do not require healing"
        settimer jaseowns_BandageTimer jaseowns_BandageTimerCD
    endwhile
    
    if skill "Healing" > 0 and findtype 3617 self 
        if timer jaseowns_BandageTimer >= jaseowns_BandageTimerCD and not targetexists
            // and not queued
            if poisoned or findbuff "disease" or findbuff "bleed"
                hotkey "Bandage Self"
            elseif not varexist jaseowns_AutoBandageHpDiffTrigger
                if hp < maxhp
                    hotkey "Bandage Self"
                endif
            elseif diffhits > jaseowns_AutoBandageHpDiffTrigger 
                hotkey "Bandage Self"
            endif
            getlabel backpack jaseowns_PingCheck
            if insysmsg "You begin applying"
                settimer jaseowns_BandageTimer 0
            endif
        endif
    endif
    
    if jaseowns_Thief_AlertRedPouchPop = 1 and counttype 3705 backpack 38 as jaseowns_RedPouchCount
        if jaseowns_RedPouchCountTotal != 0 and jaseowns_RedPouchCountTotal != jaseowns_RedPouchCount
            overhead "Warning: THIEF we lost a pouch!" 34
        else
            @setvar! jaseowns_RedPouchCountTotal jaseowns_RedPouchCount    
        endif
    endif

    if casting 
        settimer jaseowns_UseItemTimer 0
    endif

    if not queued and find jaseowns_BOT_CurrentRightHandWeapon backpack and timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
        dclick jaseowns_BOT_CurrentRightHandWeapon
        settimer jaseowns_UseItemTimer 0
    elseif not queued and find jaseowns_BOT_CurrentLeftHandWeapon backpack and timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
        dclick jaseowns_BOT_CurrentLeftHandWeapon
        settimer jaseowns_UseItemTimer 0
    endif
    
    if jaseowns_Tamer_SayAllGuard = 1 and followers > 0
        if timer jaseowns_Tamer_SayAllGuardTimer >= jaseowns_Tamer_SayAllGuardTimerCD
            say "all guard me" 89
            settimer jaseowns_Tamer_SayAllGuardTimer 0
        endif
    endif

    if jaseowns_Poison_AutomaticallyApply = 1 and skill "Poisoning" >= 50 and timer jaseowns_BOT_PoisonWeaponTimer >= jaseowns_BOT_PoisonWeaponTimerCD
        if counttype 3850 jaseowns_PotionSatchel or counttype 3850 backpack
            @setvar! jaseowns_BOT_CurrentWeapon 0
            if findlayer self righthand as jaseowns_RightHandWeapon
                @setvar! jaseowns_BOT_CurrentWeapon jaseowns_RightHandWeapon
            elseif findlayer self lefthand as jaseowns_LeftHandWeapon
                @setvar! jaseowns_BOT_CurrentWeapon jaseowns_LeftHandWeapon
            endif
            if jaseowns_BOT_CurrentWeapon != 0
                getlabel jaseowns_BOT_CurrentWeapon jaseowns_BOT_CurrentWeaponDesc
                if "poison charge" in jaseowns_BOT_CurrentWeaponDesc
                    @setvar! jaseowns_BOT_Poisoner_UseBane 1
                    settimer jaseowns_BOT_PoisonWeaponTimer 4000
                    if jaseowns_Poison_AutomaticallyApplyAtSingleCharge = 1 
                       if "(1 lethal" in jaseowns_BOT_CurrentWeaponDesc or "(1 deadly" in jaseowns_BOT_CurrentWeaponDesc or "(1 greater" in jaseowns_BOT_CurrentWeaponDesc
                            menu jaseowns_BOT_CurrentWeapon 0
                            settimer jaseowns_BOT_PoisonWeaponTimer 0
                        endif
                    endif
                    // do nothing (add a timer to avoid checking this nonstop)
                else
                    menu jaseowns_BOT_CurrentWeapon 0
                    settimer jaseowns_BOT_PoisonWeaponTimer 0
                endif
            endif
        endif
    endif

    if varexist jaseowns_Weight_GoldToDropIfOverweight and weight > maxweight and timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
        if findtype "gold coin" backpack as item
            lift item jaseowns_Weight_GoldToDropIfOverweight
            droprelloc 0 0
            getlabel backpack jaseowns_PingCheck
            if insysmsg "cannot drop anything"
                drop backpack -1 -1 -1
            endif
            settimer jaseowns_UseItemTimer 0
        else
            overhead "We are overweight and cannot drop anything" 34
        endif
    endif
    
    if jaseowns_Potion_ShowOverheads = 1
    
        if timer jaseowns_Potion_Cure_Overhead_IfCountIsLessThan_Timer >= jaseowns_Potion_Cure_Overhead_IfCountIsLessThan_TimerCD
            @setvar! jaseowns_BOT_CurePotionCount 0
            if counttype 3847 jaseowns_PotionSatchel as jaseowns_TempPotionCount
                @setvar! jaseowns_BOT_CurePotionCount jaseowns_TempPotionCount
            elseif counttype 3847 backpack as jaseowns_TempPotionCount
                @setvar! jaseowns_BOT_CurePotionCount jaseowns_TempPotionCount
            endif
            if jaseowns_BOT_CurePotionCount < jaseowns_Potion_Cure_Overhead_IfCountIsLessThan
                if jaseowns_BOT_CurePotionCount = 0
                    overhead "Cure: Out of cures" 34
                else
                    overhead "Cures Remaining: {{jaseowns_BOT_CurePotionCount}}"
                endif
            endif
            settimer jaseowns_Potion_Cure_Overhead_IfCountIsLessThan_Timer 0
        endif
        
        if timer jaseowns_Potion_Heal_Overhead_IfCountIsLessThan_Timer >= jaseowns_Potion_Heal_Overhead_IfCountIsLessThan_TimerCD
            @setvar! jaseowns_BOT_HealPotionCount 0
            if counttype 3852 jaseowns_PotionSatchel as jaseowns_TempPotionCount
                @setvar! jaseowns_BOT_HealPotionCount jaseowns_TempPotionCount
            elseif counttype 3852 backpack as jaseowns_TempPotionCount
                @setvar! jaseowns_BOT_HealPotionCount jaseowns_TempPotionCount
            endif
            if jaseowns_BOT_HealPotionCount < jaseowns_Potion_Heal_Overhead_IfCountIsLessThan
                if jaseowns_BOT_HealPotionCount = 0
                    overhead "Heal: Out of heals" 34
                else
                    overhead "Heal Remaining: {{jaseowns_BOT_HealPotionCount}}"
                endif
            endif
            settimer jaseowns_Potion_Heal_Overhead_IfCountIsLessThan_Timer 0
        endif
        
        if timer jaseowns_Potion_Explosion_Overhead_IfCountIsLessThan_Timer >= jaseowns_Potion_Explosion_Overhead_IfCountIsLessThan_TimerCD
            @setvar! jaseowns_BOT_ExplosionPotionCount 0
            if counttype 3853 jaseowns_PotionSatchel as jaseowns_TempPotionCount
                @setvar! jaseowns_BOT_ExplosionPotionCount jaseowns_TempPotionCount
            elseif counttype 3853 backpack as jaseowns_TempPotionCount
                @setvar! jaseowns_BOT_ExplosionPotionCount jaseowns_TempPotionCount
            endif
