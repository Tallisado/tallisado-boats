                elseif jaseowns_SwitchTo = 3
                    say "[ShieldsStance3"
                elseif jaseowns_SwitchTo = 4
                    say "[ShieldsStance4"
                elseif jaseowns_SwitchTo = 5
                    say "[ShieldsStance5"
