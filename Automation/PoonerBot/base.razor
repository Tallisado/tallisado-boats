            overhead 'Drinking heal!' 2091
            potion "heal"
            wait 200
            settimer "healpot" 0
        endif
    else
         overhead 'Out of heals!' 34
    endif
endif
    
while poisoned and hits <= CurepotHP and not targetexists 
    if findtype "Orange Potion" backpack as curepot and timer "curepot" >= 1000
