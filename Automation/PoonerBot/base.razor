## Bandage self & crew
if skill "Healing" >= 20 and findtype 3617 backpack as baids
    if hp < maxhp and timer "bandage" >= 10200 and findtype 3617 backpack and not bandaging
        hotkey "Bandage Self"
        settimer "bandage" 0
    elseif gumpexists 1722920179 and timer "AutoHealSpam" >= AutoHealSpam
        if varexist 'ManualTargetFriendly' and not bandaging
            overhead "Medic!" 88 'ManualTargetFriendly'
            while queued
                //donothing
            endwhile
            dclick baids
            wft 500
            target 'ManualTargetFriendly'
            getlabel backpack ping
            if insysmsg "You are too far away to do that"
                overhead "* FAR *" 88 'ManualTargetFriendly'
                overhead "* FAR *" 88 'ManualTargetFriendly'
                overhead "* FAR *" 88 'ManualTargetFriendly'
            elseif insysmsg "That being is not damaged!"
                overhead "Healthy!" 88 'ManualTargetFriendly'
                unsetvar 'ManualTargetFriendly'
                settimer HealCrew CrewHealCD
            else
                overhead "Healing fumble!" 88
                unsetvar 'ManualTargetFriendly'
                settimer HealCrew CrewHealCD
            endif
            if targetexists
                hotkey "Cancel Current Target"
            endif
        endif
        if timer HealCrew >= CrewHealCD
            if not bandaging
                waitforgump 1722920179
                gumpresponse 20 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 21 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 22 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 23 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 24 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 25 1722920179
            endif
            if not bandaging
                waitforgump 1722920179 
                gumpresponse 26 1722920179
            endif
            if not bandaging
                waitforgump 1722920179 
                gumpresponse 27 1722920179
            endif
            settimer HealCrew 0
        endif
        settimer "AutoHealSpam" 0
    endif
    if not gumpexists 1722920179
       say "[shiphotbars"
       waitforgump 1722920179 500
    endif 
endif

