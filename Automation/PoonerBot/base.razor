    endif

    // Attacking stuff
    if jaseowns_CurrentBotTargetAttacked = 1
        
        if jaseowns_Healing_AidCountAlertLessThan20 = 1 and skill "Healing" > 0 and counttype 3617 self as jaseowns_BOT_AidCount
            if 20 > jaseowns_BOT_AidCount
            overhead "We are low on aids {{jaseowns_BOT_AidCount}}" 34
            endif
        endif
    
        if jaseowns_Potion_UseCleansingBrewAutomatically = 1 and findtype 50675 backpack 2935 as jaseowns_UseItem
