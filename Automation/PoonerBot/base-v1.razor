    if not queued and jaseowns_Potion_UseCureAutomatically = 1 and poisoned and diffhits >= jaseowns_Potion_CureHpDiffTrigger and findtype 3847 self as jaseowns_Potion
        if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
            dclick jaseowns_Potion
            settimer jaseowns_UseItemTimer 0
        endif
    endif
    
    if jaseowns_Potion_UseHealAutomatically = 1 and diffhits >= jaseowns_Potion_HealHpDiffTrigger and findtype 3852 self as jaseowns_Potion
