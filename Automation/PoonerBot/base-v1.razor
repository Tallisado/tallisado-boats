                overhead "Frost Already Enabled" 2234
            else 
                cooldown "Aspect" 30000
                overhead "--Frost Shell Primed--" 2234
            endif
        else
            overhead "Aspect Cooling..." 45
        endif
    endif
    ## Ocean: Find Bombs on Deck
    if findtype "5188" ground -1 -1 22 as bomb
        overhead "***BOMB***" 34 bomb
    endif

    if not queued and find jaseowns_BOT_CurrentRightHandWeapon backpack and timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
        dclick jaseowns_BOT_CurrentRightHandWeapon
        settimer jaseowns_UseItemTimer 0
    elseif not queued and find jaseowns_BOT_CurrentLeftHandWeapon backpack and timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
        dclick jaseowns_BOT_CurrentLeftHandWeapon
        settimer jaseowns_UseItemTimer 0
    endif

