while not dead

    // Handle manual bandage
    while insysmsg "You begin applying" or insysmsg "You begin using veterinary supplies"
        settimer jaseowns_BandageTimer 0
    endwhile

    // Reset the timer if we finished
    while insysmsg "You finish applying"
        settimer jaseowns_BandageTimer jaseowns_BandageTimerCD
    endwhile
    
    if skill "Healing" > 0 and findtype 3617 self
        if timer jaseowns_BandageTimer >= jaseowns_BandageTimerCD
            if poisoned or findbuff "disease" or findbuff "bleed"
                hotkey "Bandage Self"
            elseif not varexist jaseowns_AutoBandageHpDiffTrigger
                if hp < maxhp
                    hotkey "Bandage Self"
                endif
            elseif diffhits > jaseowns_AutoBandageHpDiffTrigger 
                hotkey "Bandage Self"
            endif
        endif
        getlabel backpack jaseowns_PingCheck
        if insysmsg "You begin applying"
            overhead "Self Heal" 45
            cooldown 'Self Heal' tallis_Ocean_SelfHealBandages_TimerCD
            settimer jaseowns_BandageTimer 0
        endif
        // OCEAN MOD
        if varexist 'ManualTargetFriendly' and not bandaging and findtype 3617 backpack as baids
            //if findtype 'ManualTargetFriendly' ground -1 -1 22 as hommie
            overhead "Medic!" 88 'ManualTargetFriendly'
            while queued
                //donothing
            endwhile
            dclick baids
            wft 500
            target 'ManualTargetFriendly'
            getlabel backpack ping
        
            if insysmsg "You are too far away to do that"
                overhead "|--| FAR |--|" 88 'ManualTargetFriendly'
            elseif insysmsg "That being is not damaged!"
                overhead "Healthy!" 88 'ManualTargetFriendly'
                unsetvar 'ManualTargetFriendly'
            endif
            //else
                //unsetvar 'ManualTargetFriendly'
            //endif
        elseif not bandaging and findtype 3617 backpack as baids
            if not gumpexists 1722920179
                overhead 'We need to open the Crew Gump' 
                say "[ShipHotbars"
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 20 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 21 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 22 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 23 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 24 1722920179
            endif
            if not bandaging
                waitforgump 1722920179
                gumpresponse 25 1722920179
            endif
             if not bandaging
                waitforgump 1722920179 
                gumpresponse 26 1722920179
            endif
            if not bandaging
                waitforgump 1722920179 
                gumpresponse 27 1722920179
            endif
        endif
        // OCEAN MOD
    endif
    
