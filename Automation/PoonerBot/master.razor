            elseif "Warding" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 2
            elseif "Testudo" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 3
            elseif "Mirror" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 4
            elseif "Bulwark" in jaseowns_ParryCodexDesc
                @setvar! jaseowns_ActiveParryCodex 5
            endif
            
            if findbuff "bleed" and jaseowns_Parry_SwitchToWardingIfBleeding = 1 and diffhits >= jaseowns_Parry_SwitchToWardingIfBleedingHpDiff
                @setvar! jaseowns_SwitchTo 2
            elseif findbuff "disease" and jaseowns_Parry_SwitchToWardingIfDisease = 1 and diffhits >= jaseowns_Parry_SwitchToWardingIfDiseaseHpDiff
                @setvar! jaseowns_SwitchTo 2
            elseif poisoned and jaseowns_Parry_SwitchToWardingIfPoison = 1 and diffhits >= jaseowns_Parry_SwitchToWardingIfPoisonHpDiff
                @setvar! jaseowns_SwitchTo 2
            elseif jaseowns_Parry_SwitchToBulwarkIfStandingStill = 1 and not cooldown "Bulwark"
                @setvar! jaseowns_SwitchTo 5
            elseif jaseowns_Parry_SwitchToShieldBashWhileMoving = 1 and cooldown "Moving"
                @setvar! jaseowns_SwitchTo 1
            elseif varexist jaseowns_Parry_SwitchToDefaultStance
                @setvar! jaseowns_SwitchTo jaseowns_Parry_SwitchToDefaultStance
            else
                @setvar! jaseowns_SwitchTo 0
            endif
            
            if jaseowns_ActiveParryCodex != jaseowns_SwitchTo
