                @setvar! jaseowns_BOT_ExplosionPotionCount jaseowns_TempPotionCount
            elseif counttype 3853 backpack as jaseowns_TempPotionCount
                @setvar! jaseowns_BOT_ExplosionPotionCount jaseowns_TempPotionCount
            endif
            if jaseowns_BOT_ExplosionPotionCount < jaseowns_Potion_Explosion_Overhead_IfCountIsLessThan
                if jaseowns_BOT_ExplosionPotionCount = 0
