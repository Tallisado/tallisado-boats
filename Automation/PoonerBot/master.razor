                    overhead "Explosion Remaining: {{jaseowns_BOT_ExplosionPotionCount}}"
                endif
            endif
            settimer jaseowns_Potion_Explosion_Overhead_IfCountIsLessThan_Timer 0
        endif
        
    endif

    #overhead "Potion logic: {{DebugTimer}}"
    
    # Potion Overheads

    //findtype 3847 self

    if not queued and not findbuff "food" and findtype "tray" backpack as jaseowns_FoodItem
        if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
            dclick jaseowns_FoodItem
            settimer jaseowns_UseItemTimer 0
        endif
    endif
    
    if jaseowns_HasPanacea = 1 and timer jaseowns_UsePanaceaTimer >= jaseowns_UsePanaceaTimerCD
        if findbuff "bleed" or findbuff "disease"
            if findtype 3847 self 0 as jaseowns_UseItem
                dclick jaseowns_UseItem
                cooldown "Panacea" jaseowns_UsePanaceaTimerCD
                settimer jaseowns_UsePanaceaTimer 0
            endif
        endif
    endif
    
    # Potions
    if not queued and jaseowns_Potion_UseCureAutomatically = 1 and poisoned and diffhits >= jaseowns_Potion_CureHpDiffTrigger and findtype 3847 self as jaseowns_Potion
        if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
            dclick jaseowns_Potion
            settimer jaseowns_UseItemTimer 0
        endif
    endif
    
    if jaseowns_Potion_UseHealAutomatically = 1 and diffhits >= jaseowns_Potion_HealHpDiffTrigger and findtype 3852 self as jaseowns_Potion
        if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
            getlabel jaseowns_Potion jaseowns_PotionDesc
            if "next usable in" in jaseowns_PotionDesc
                // do nothing
            else
                dclick jaseowns_Potion
                settimer jaseowns_UseItemTimer 0
            endif
        endif
    endif

    if not queued and jaseowns_Potion_UseRefreshAutomatically = 1 and diffstam >= jaseowns_Potion_RefreshStamDiffTrigger and findtype 3851 self as jaseowns_Potion
        if timer jaseowns_UseItemTimer >= jaseowns_UseItemTimerCD
            dclick jaseowns_Potion
            settimer jaseowns_UseItemTimer 0
        endif
    endif
    
    // Trapped
    if paralyzed and not queued 
        if findtype "pouch" backpack 38 
            yell "[pouch"
            getlabel backpack jaseowns_PingCheck
        else
            overhead "Out of Pouches!" 34
        endif
    endif

    if not queued and jaseowns_UseSkinningKnifeAutomatically = 1 and findtype 11552 backpack as jaseowns_SkinningKnife
        if findbuff "Actively Meditating"
            //do nothing
        elseif findtype 8198 ground -1 -1 2 as jaseowns_Corpse
            while not targetexists 
                dclick jaseowns_SkinningKnife
                wft 500
            endwhile
            while targetexists 
                hotkey "Target Self"
                getlabel backpack jaseowns_PingCheck
            endwhile
            @ignore jaseowns_Corpse
        endif
    endif
    
    if skill "Tracking" > 0
        if not findbuff "tracking"
            clearsysmsg
            while not gumpexists 4267467659
                useskill 'tracking'
                getlabel backpack jaseowns_PingCheck
            endwhile
            if gumpexists 4267467659
                while not insysmsg "You will now hunt all hostile players."
                    gumpresponse 8 4267467659
                    waitforgump 4267467659 5000
                endwhile
                gumpresponse 6 4267467659
                getlabel backpack jaseowns_PingCheck
            endif
            gumpclose 4267467659
        endif
    endif
    if skill "Healing" > 0 and findtype 3617 self and not bandaging    
        if skill "Healing" > 0 and findtype 3617 self and not bandaging 
            if findbuff "bleed" or findbuff "disease" or poisoned
                hotkey "Bandage Self"
            elseif not varexist jaseowns_AutoBandageHpDiffTrigger
                if hp < maxhp
                    hotkey "Bandage Self"
                endif
            elseif diffhits > jaseowns_AutoBandageHpDiffTrigger 
                hotkey "Bandage Self"
            endif
         endif
         
         if varexist manualCrewHeal and timer undead_Ocean_CrewHealBandages_Timer >= undead_Ocean_CrewHealBandages_TimerCD and findtype 3617 backpack as baids
            overhead "Focus Healing" lasttarget
            hotkey "Bandage LastTarget"
            cooldown 'Crew Heal' undead_Ocean_CrewHealBandages_TimerCD
         elseif timer undead_Ocean_CrewHealBandages_Timer >= undead_Ocean_CrewHealBandages_TimerCD 
            if not gumpexists 1722920179
                overhead 'We need to open the Crew Gump' 
                say "[ShipHotbars"
            endif
            waitforgump 1722920179
            if not bandaging and gumpexists 1722920179 
                gumpresponse 20 1722920179
                cooldown 'Crew Heal' undead_Ocean_CrewHealBandages_TimerCD
            endif
            if not bandaging and gumpexists 1722920179
                gumpresponse 21 1722920179
