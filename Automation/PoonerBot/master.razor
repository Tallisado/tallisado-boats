                wait 50
            endwhile
            getlabel backpack jaseowns_PingCheck
            if insysmsg "Last Target set."
                overhead "New target selected!" 89 lasttarget
                @setvar! jaseowns_CurrentBotTarget lasttarget 
            endif
        endif
    
        // do fighting
        if not find jaseowns_CurrentBotTarget
            hotkey "target closest non-friendly monster"
            @setvar! jaseowns_LastBotTarget lasttarget 
            if jaseowns_CurrentBotTarget != jaseowns_LastBotTarget
                @setvar! jaseowns_CurrentBotTarget jaseowns_LastBotTarget
            endif
        endif
        
        # TODO: handle hidden mobs
        if not dead jaseowns_CurrentBotTarget
            
            if timer jaseowns_CurrentBotTargetOverheadTimer >= jaseowns_CurrentBotTargetOverheadTimerCD and listexists jaseowns_CurrentBotTargetOverheadText
                foreach jaseowns_Overhead in jaseowns_CurrentBotTargetOverheadText
                    overhead jaseowns_Overhead jaseowns_CurrentBotTargetOverheadHue jaseowns_CurrentBotTarget
                endfor
                settimer jaseowns_CurrentBotTargetOverheadTimer 0
            endif

            if find jaseowns_CurrentBotTarget ground -1 -1 jaseowns_FightingRangeCheck
                
                for 3
                    if dead jaseowns_CurrentBotTarget
                        break
                    endif
                    getlabel jaseowns_CurrentBotTarget jaseowns_CurrentBotTargetDesc
                    if "-" in jaseowns_CurrentBotTargetDesc
                        // do nothing - try again
                    else
                        break
                    endif
                endfor
                @setvar! jaseowns_IgnoreCurrentBotTarget 0
                
                if "(summoned" in jaseowns_CurrentBotTargetDesc or "(bonded" in jaseowns_CurrentBotTargetDesc or "(tame" in jaseowns_CurrentBotTargetDesc
                    overhead "▼ Player pet - IGNORE ▼" 77 jaseowns_CurrentBotTarget
                    @setvar! jaseowns_IgnoreCurrentBotTarget 1
                elseif listexists jaseowns_IgnoreMobList
                    foreach jaseowns_IgnoreMob in jaseowns_IgnoreMobList
                        if jaseowns_IgnoreMob in jaseowns_CurrentBotTargetDesc
                            if timer jaseowns_IgnoreMobOverheadTimer >= jaseowns_IgnoreMobOverheadTimerCD and listexists jaseowns_IgnoreMobOverheadText
                                foreach jaseowns_Overhead in jaseowns_IgnoreMobOverheadText
                                    overhead jaseowns_Overhead jaseowns_IgnoreMobOverheadHue  jaseowns_CurrentBotTarget
                                endfor
                                settimer jaseowns_IgnoreMobOverheadTimer 0
                            endif
                            @setvar! jaseowns_IgnoreCurrentBotTarget 1
                        endif
                    endfor
                endif

                if jaseowns_IgnoreCurrentBotTarget = 1 or dead jaseowns_CurrentBotTarget
                    @setvar! jaseowns_CurrentBotTarget 0
                else
                    
                
                    attack jaseowns_CurrentBotTarget
                
                    # bard stuff here

